{
    "name": "koppa-lang",
    "displayName": "KOPPA Language Support",
    "description": "Cybersecurity Programming Language KOPPA",
    "version": "1.0.0",
    "publisher": "Korku",
    "engines": {
        "vscode": "^1.50.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [{
            "id": "koppa",
            "aliases": ["KOPPA", "koppa"],
            "extensions": [".kop", ".apo"],
            "configuration": "./language-configuration.json"
        }],
        "grammars": [{
            "language": "koppa",
            "scopeName": "source.koppa",
            "path": "./syntaxes/koppa.tmLanguage.json"
        }],
        "iconThemes": [{
            "id": "koppa-icons",
            "label": "KOPPA Icons",
            "path": "./icons/icon-theme.json"
        }]
    }
}
